            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/vms/{name}": {
      "put": {
        "description": "Met à jour les propriétés d'une VM existante. Opération idempotente.",
        "tags": [
          "VMs"
        ],
        "summary": "Met à jour une machine virtuelle",
        "responses": {
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "description": "Conflit (ex: VM en cours d'exécution)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "200": {
            "description": "VM mise à jour ou inchangée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmActionResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmUpdateRequest"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom de la VM",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "delete": {
        "description": "Supprime une VM et ses disques associés. Opération idempotente.",
        "tags": [
          "VMs"
        ],
        "summary": "Supprime une machine virtuelle",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "VM supprimée",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "deleted": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom de la VM",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "get": {
        "description": "Retourne les informations détaillées d'une machine virtuelle spécifique",
        "tags": [
          "VMs"
        ],
        "summary": "Récupère les détails d'une VM",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "Détails de la VM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vm"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom de la VM",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "openapi": "3.0.3",
  "info": {
    "version": "1.0.0",
    "description": "REST API layer on top of Microsoft Hyper-V using PowerShell and Pode",
    "title": "Hyper-V API Overlay"
  },
  "components": {
    "responses": {
      "Error": {
        "description": "Erreur serveur",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Requête invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "VmCreateRequest": {
        "required": [
          "name",
          "memoryMB",
          "vcpu",
          "diskPath",
          "diskGB",
          "switchName"
        ],
        "properties": {
          "switchName": {
            "description": "Nom du switch virtuel",
            "type": "string"
          },
          "vcpu": {
            "description": "Nombre de vCPU",
            "type": "integer"
          },
          "name": {
            "description": "Nom de la VM",
            "type": "string"
          },
          "diskGB": {
            "description": "Taille du disque en GB",
            "type": "integer"
          },
          "diskPath": {
            "description": "Chemin du disque",
            "type": "string"
          },
          "isoPath": {
            "description": "Chemin vers l'ISO (optionnel)",
            "type": "string"
          },
          "memoryMB": {
            "description": "Mémoire en MB",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "Error": {
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "description": "Message d'erreur lisible",
            "type": "string"
          },
          "detail": {
            "description": "Message technique optionnel",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Vm": {
        "properties": {
          "State": {
            "type": "string"
          },
          "MemoryAssigned": {
            "type": "integer"
          },
          "CPUUsage": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          },
          "Uptime": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "root": {
            "type": "string"
          },
          "time": {
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        },
        "type": "object"
      },
      "VmActionResponse": {
        "properties": {
          "restarted": {
            "type": "string"
          },
          "updated": {
            "type": "boolean"
          },
          "deleted": {
            "type": "string"
          },
          "unchanged": {
            "type": "boolean"
          },
          "stopped": {
            "type": "string"
          },
          "started": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "resumed": {
            "type": "string"
          },
          "exists": {
            "type": "string"
          },
          "suspended": {
            "type": "string"
          },
          "created": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "SwitchCreateRequest": {
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "netAdapterName": {
            "description": "Nom de l'adaptateur réseau (requis pour External)",
            "type": "string"
          },
          "notes": {
            "description": "Notes optionnelles",
            "type": "string"
          },
          "name": {
            "description": "Nom du switch",
            "type": "string"
          },
          "type": {
            "enum": [
              "Internal",
              "Private",
              "External"
            ],
            "description": "Type de switch",
            "type": "string"
          }
        },
        "type": "object"
      },
      "VmUpdateRequest": {
        "properties": {
          "switchName": {
            "description": "Nom du switch virtuel",
            "type": "string"
          },
          "isoPath": {
            "description": "Chemin vers l'ISO",
            "type": "string"
          },
          "vcpu": {
            "description": "Nombre de vCPU",
            "type": "integer"
          },
          "memoryMB": {
            "description": "Mémoire en MB",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "Switch": {
        "properties": {
          "SwitchType": {
            "enum": [
              "Internal",
              "Private",
              "External"
            ],
            "type": "string"
          },
          "Notes": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "SwitchUpdateRequest": {
        "properties": {
          "notes": {
            "description": "Notes",
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "servers": [
    {
      "description": "Hyper-V Host API Server",
      "url": "http://0.0.0.0:8080"
    }
  ]
}
