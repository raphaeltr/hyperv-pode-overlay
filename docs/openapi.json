{
  "paths": {
    "/vms/{name}/restart": {
      "post": {
        "description": "Redémarre une VM de manière gracieuse ou forcée. Si la VM est arrêtée, elle sera démarrée. Opération idempotente.",
        "tags": [
          "VMs"
        ],
        "summary": "Redémarre une machine virtuelle",
        "responses": {
          "422": {
            "description": "Service d'intégration d'arrêt non disponible",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "VM redémarrée",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "restarted": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "force": {
                    "description": "Force le redémarrage si true",
                    "type": "boolean"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom de la VM",
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "force",
            "required": false,
            "description": "Force le redémarrage si true",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ]
      }
    },
    "/vms/{name}/start": {
      "post": {
        "description": "Démarre une VM. Opération idempotente.",
        "tags": [
          "VMs"
        ],
        "summary": "Démarre une machine virtuelle",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "VM démarrée",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "started": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom de la VM",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/switches/{name}": {
      "put": {
        "description": "Met à jour les notes d'un switch. Seul le champ notes est modifiable. Opération idempotente.",
        "tags": [
          "Switches"
        ],
        "summary": "Met à jour un switch virtuel",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "Switch mis à jour",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "updated": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SwitchUpdateRequest"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom du switch",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "delete": {
        "description": "Supprime un switch virtuel. Opération idempotente.",
        "tags": [
          "Switches"
        ],
        "summary": "Supprime un switch virtuel",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "Switch supprimé",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "deleted": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom du switch",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "get": {
        "description": "Retourne les informations détaillées d'un switch virtuel spécifique",
        "tags": [
          "Switches"
        ],
        "summary": "Récupère les détails d'un switch",
        "responses": {
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "200": {
            "description": "Détails du switch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Switch"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "name",
            "required": true,
            "description": "Nom du switch",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/health": {
